{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "analyze": "ANALYZE=true next build",
    "size": "size-limit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tanstack/react-query": "^5.67.1",
    "graphql": "^16.10.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^15.5.15",
    "@playwright/test": "^1.44.0",
    "@size-limit/file": "^11.0.0",
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.3",
    "size-limit": "^11.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.4.2",
    "vitest": "^2.0.0"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/*.js",
      "limit": "300 kB"
    }
  ]
}
