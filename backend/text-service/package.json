{
  "name": "text-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@apollo/server": "^4.0.0",
    "@apollo/subgraph": "^2.13.2",
    "@nestjs/axios": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sentry/nestjs": "^10.49.0",
    "@sentry/profiling-node": "^10.49.0",
    "axios": "*",
    "express": "*",
    "graphql": "*",
    "graphql-tag": "*",
    "pg": "^8.20.0",
    "reflect-metadata": "*",
    "rxjs": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "*",
    "@types/dotenv": "^8.2.3",
    "@types/express": "*",
    "@types/node": "*",
    "@types/pg": "^8.18.0",
    "prisma": "^7.4.2",
    "ts-node": "*",
    "typescript": "*",
    "vitest": "^3.0.0"
  }
}