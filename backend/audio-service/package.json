{
  "name": "audio-service",
  "version": "1.0.0",
  "description": "Audio service for the Lingo project",
  "main": "dist/main.js",
  "scripts": {
    "start": "ts-node src/main.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "start:prod": "node dist/main.js",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@prisma/client": "^6.16.3",
    "axios": "^1.13.6",
    "dotenv": "^10.0.0",
    "form-data": "^4.0.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^9.0.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^20.0.0",
    "jest": "^27.0.0",
    "prisma": "^6.16.3",
    "ts-jest": "^27.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testRegex": "\\.spec\\.ts$",
    "moduleNameMapper": {
      "^axios$": "axios/dist/node/axios.cjs"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "strict": false,
          "experimentalDecorators": true,
          "emitDecoratorMetadata": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "types": ["jest", "node"]
        }
      }
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "license": "MIT"
}